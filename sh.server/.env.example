# Server
PORT=3000

# PostgreSQL (khớp với docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sh_user
POSTGRES_PASSWORD=sh_password
POSTGRES_DB=smart_hospital

# JWT (đổi secret khi deploy)
JWT_SECRET=smart-hospital-secret-change-in-production

# URL gốc web client (link trong email quên mật khẩu). Repo này: sh.client dev dùng vite --port=5431
CLIENT_APP_URL=http://localhost:5431

# SMTP — Nodemailer (quên mật khẩu). Ví dụ Gmail App Password: SMTP_PORT=587, SMTP_SECURE=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# MAIL_FROM=SmartHospital <noreply@yourdomain.com>

# Connection string (NestJS/TypeORM dùng từng biến hoặc URL)
# DATABASE_URL=postgresql://sh_user:sh_password@localhost:5432/smart_hospital

# Public URL API (sau khi chạy npm run ngrok, copy URL vào đây). Webhook PayOS = https://YOUR_NGROK_URL/payments/payos-webhook
# PUBLIC_API_URL=

# PayOS (https://my.payos.vn)
# PAYOS_CLIENT_ID=
# PAYOS_API_KEY=
# PAYOS_CHECKSUM_KEY=

# OpenAI — tính năng AI (gợi ý chuyên khoa, RAG hồ sơ bệnh án, v.v.)
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
