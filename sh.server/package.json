{
  "name": "sh.server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:init": "docker compose up -d",
    "db:schema": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < db.sql",
    "db:reset": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < reset-db.sql",
    "db:alter": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < alter-users-add-role-and-doctor-fields.sql",
    "db:seed": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < seed-data.sql",
    "db:migrate:payos": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < migrations/add-payos-order-code.sql",
    "db:migrate:university-text": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < migrations/university-text-on-users.sql",
    "db:migrate:university-text:env": "node scripts/apply-university-text-migration.cjs",
    "db:migrate:slots-weekdays": "docker exec -i sh-postgres psql -U sh_user -d smart_hospital < migrations/slots-weekday-only.sql",
    "db:migrate:slots-weekdays:env": "node scripts/apply-slots-weekday-migration.cjs",
    "db:migrate:doctor-leave:env": "node scripts/apply-doctor-leave-migration.cjs",
    "db:migrate:slot-on-leave:env": "node scripts/apply-slot-status-on-leave-migration.cjs",
    "db:migrate:medical-core:env": "node scripts/apply-medical-records-core-migration.cjs",
    "db:migrate:medical-rag:env": "node scripts/apply-medical-records-rag-migration.cjs",
    "ngrok": "ngrok http 3000",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1048.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.0",
    "@sendgrid/mail": "8.1.6",
    "bcrypt": "^6.0.0",
    "nodemailer": "^6.10.1",
    "openai": "^6.37.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.23",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
